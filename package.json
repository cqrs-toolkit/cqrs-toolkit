{
  "name": "cqrs-toolkit",
  "version": "1.0.0",
  "description": "Shared CQRS client and server utilities",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20.12.0"
  },
  "workspaces": [
    "packages/*",
    "demos/*"
  ],
  "scripts": {
    "build": "tsc --build tsconfig.build.json && npm run compile --workspaces --if-present && npm run build --workspace=packages/devtools",
    "test": "vitest --project unit-*",
    "test:run": "vitest --project unit-* --run",
    "dev": "npm run dev -w @cqrs-toolkit/todo-demo",
    "docs": "npm run docs --workspaces --if-present",
    "format:all": "prettier --write packages demos",
    "test:e2e": "npx playwright test --config demos/todo-demo/playwright.config.ts",
    "test:extension": "npx playwright test --config demos/todo-demo/playwright.extension.config.ts",
    "format": "./scripts/format-changed.sh",
    "precommit": "npm run docs && git add . && npm run format && npm run test:run",
    "postinstall": "node .husky/install.mjs"
  },
  "lint-staged": {
    "**/*.md": [
      "npx prettier --write"
    ],
    "**/*.{ts,tsx}": [
      "npx prettier --write"
    ]
  },
  "peerDependencies": {
    "@meticoeus/ddd-es": ">=0.7.2"
  },
  "devDependencies": {
    "@meticoeus/ddd-es": "^0.7.2",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.7.6",
    "husky": "^9.1.6",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vitest": "^2.1.3"
  }
}
