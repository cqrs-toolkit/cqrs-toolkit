{
  "name": "@cqrs-toolkit/hypermedia-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack hypermedia demo for @cqrs-toolkit",
  "license": "MIT",
  "author": "Ontel, LLC",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "tsx server/server.ts",
    "client": "vite",
    "client:peer": "vite --port 5176",
    "compile": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "generate-meta": "tsx cli/generate-meta.ts",
    "cqrs-init": "cqrs-pull init --server=http://localhost:3002 --apidoc-path=/api/meta/apidoc",
    "cqrs-generate": "NODE_OPTIONS='--import tsx/esm' cqrs-pull generate"
  },
  "dependencies": {
    "@cqrs-toolkit/client": "*",
    "@cqrs-toolkit/demo-base": "*",
    "@cqrs-toolkit/client-solid": "*",
    "@cqrs-toolkit/hypermedia": "*",
    "@cqrs-toolkit/realtime": "*",
    "@meticoeus/ddd-es": "^0.7.2",
    "@solidjs/router": "^0.15.4",
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "@fastify/websocket": "^11.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.0.0",
    "fastify": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "vite-plugin-solid": "^2.11.0"
  }
}
