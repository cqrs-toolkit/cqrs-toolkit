{
  "name": "@cqrs-toolkit/hypermedia-base",
  "version": "0.1.0",
  "private": true,
  "description": "Shared hypermedia client domain code and UI for CQRS toolkit demos",
  "license": "MIT",
  "author": "Ontel, LLC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./bootstrap/cqrs-config": {
      "types": "./dist/src/bootstrap/cqrs-config.d.ts",
      "import": "./dist/src/bootstrap/cqrs-config.js"
    },
    "./bootstrap/typed-client": {
      "types": "./dist/src/bootstrap/typed-client.d.ts",
      "import": "./dist/src/bootstrap/typed-client.js"
    },
    "./pages": {
      "types": "./dist/src/pages/index.d.ts",
      "import": "./dist/src/pages/index.js"
    },
    "./components/PageShell": {
      "types": "./dist/src/components/PageShell.d.ts",
      "import": "./dist/src/components/PageShell.js"
    },
    "./primitives/createEditNavigator": {
      "types": "./dist/src/primitives/createEditNavigator.d.ts",
      "import": "./dist/src/primitives/createEditNavigator.js"
    },
    "./e2e-helpers": {
      "types": "./dist/src/e2e-helpers.d.ts",
      "import": "./dist/src/e2e-helpers.js"
    },
    "./e2e-nav": {
      "types": "./dist/src/e2e-nav.d.ts",
      "import": "./dist/src/e2e-nav.js"
    }
  },
  "imports": {
    "#bootstrap/cqrs-config": "./src/bootstrap/cqrs-config.js",
    "#bootstrap/typed-client": "./src/bootstrap/typed-client.js",
    "#pages": "./src/pages/index.js",
    "#components/PageShell": "./src/components/PageShell.js",
    "#primitives/createEditNavigator": "./src/primitives/createEditNavigator.js"
  },
  "scripts": {
    "build": "rm -rf dist && rollup -c && tsc -p tsconfig.build.json",
    "compile": "tsc -p tsconfig.json --noEmit",
    "cqrs:client:init": "cqrs-toolkit client init --server=http://localhost:3002 --apidoc-path=/api/meta/apidoc",
    "cqrs:client:pull": "cqrs-toolkit client pull"
  },
  "dependencies": {
    "@cqrs-toolkit/client": "*",
    "@cqrs-toolkit/client-solid": "*",
    "@cqrs-toolkit/demo-base": "*",
    "@cqrs-toolkit/hypermedia-client": "*",
    "@meticoeus/ddd-es": "^0.7.3",
    "@solidjs/router": "^0.15.4",
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "@cqrs-toolkit/hypermedia-cli": "*",
    "solid-js": "^1.9.0"
  }
}
