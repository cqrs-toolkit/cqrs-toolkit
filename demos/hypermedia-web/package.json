{
  "name": "@cqrs-toolkit/hypermedia-web",
  "version": "0.1.0",
  "private": true,
  "description": "Hypermedia demo web client for @cqrs-toolkit",
  "license": "MIT",
  "author": "Ontel, LLC",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "npm run server -w @cqrs-toolkit/hypermedia-server",
    "client": "vite",
    "client:peer": "vite --port 5176",
    "compile": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cqrs-toolkit/client": "*",
    "@cqrs-toolkit/client-solid": "*",
    "@cqrs-toolkit/hypermedia-base": "*",
    "@meticoeus/ddd-es": "^0.7.3",
    "@solidjs/router": "^0.15.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "concurrently": "^9.0.0",
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.2.1",
    "vite-plugin-solid": "^2.11.0"
  }
}
