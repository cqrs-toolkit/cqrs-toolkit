{
  "name": "@cqrs-toolkit/todo-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Full-stack Todo demo for @cqrs-toolkit/client",
  "license": "MIT",
  "author": "Ontel, LLC",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "tsx server/server.ts",
    "client": "vite",
    "client:peer": "vite --port 5174",
    "compile": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test:extension": "playwright test --config playwright.extension.config.ts"
  },
  "imports": {
    "#e2e-fixtures": "./src/e2e-fixtures.ts"
  },
  "dependencies": {
    "@cqrs-toolkit/client": "*",
    "@cqrs-toolkit/client-solid": "*",
    "@cqrs-toolkit/demo-base": "*",
    "@cqrs-toolkit/realtime": "*",
    "@meticoeus/ddd-es": "^0.7.3",
    "@solidjs/router": "^0.15.4",
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/websocket": "^11.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.0.0",
    "fastify": "^5.0.0",
    "form-data": "^4.0.5",
    "pino-pretty": "^13.0.0",
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.2.1",
    "uuid": "^13.0.0",
    "vite-plugin-solid": "^2.11.0"
  }
}
