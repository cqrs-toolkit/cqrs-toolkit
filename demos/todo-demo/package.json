{
  "name": "@cqrs-toolkit/todo-demo",
  "version": "0.1.0",
  "description": "Full-stack Todo demo for @cqrs-toolkit/client",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "tsx server/server.ts",
    "client": "vite",
    "compile": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@cqrs-toolkit/client": "*",
    "@cqrs-toolkit/realtime": "*",
    "@meticoeus/ddd-es": "^0.7.2",
    "@solidjs/router": "^0.15.4",
    "ajv": "^8.0.0"
  },
  "devDependencies": {
    "@fastify/websocket": "^11.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.0.0",
    "fastify": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.0.0",
    "uuid": "^13.0.0",
    "vite-plugin-solid": "^2.11.0"
  }
}
