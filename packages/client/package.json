{
  "name": "@cqrs-toolkit/client",
  "version": "0.1.0",
  "description": "Offline-first CQRS/event-sourcing client library",
  "keywords": [
    "cqrs",
    "event-sourcing",
    "offline-first",
    "rxjs"
  ],
  "license": "MIT",
  "author": "Ontel, LLC",
  "main": "dist/src/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./internals": {
      "types": "./dist/src/internals.d.ts",
      "import": "./dist/src/internals.js"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "import": "./dist/src/utils/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.build.json",
    "compile": "tsc -p tsconfig.json --noEmit",
    "docs": "typedoc",
    "test": "vitest"
  },
  "dependencies": {
    "@cqrs-toolkit/realtime": "^0.1.0",
    "@sqlite.org/sqlite-wasm": "^3.48.0-build1",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.8.0",
    "fake-indexeddb": "^6.0.0"
  }
}
