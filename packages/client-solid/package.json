{
  "name": "@cqrs-toolkit/client-solid",
  "version": "0.1.0",
  "description": "SolidJS reactive primitives for @cqrs-toolkit/client",
  "keywords": [
    "cqrs",
    "event-sourcing",
    "solidjs",
    "reactive"
  ],
  "license": "MIT",
  "author": "Ontel, LLC",
  "main": "dist/src/index.js",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && rm -rf dist && rollup -c && tsc -p tsconfig.build.json",
    "compile": "tsc -p tsconfig.json --noEmit",
    "docs": "typedoc",
    "test": "vitest"
  },
  "dependencies": {
    "@cqrs-toolkit/client": "^0.1.0"
  },
  "devDependencies": {
    "rxjs": "^7.8.1",
    "solid-js": "^1.9.0"
  },
  "peerDependencies": {
    "solid-js": "^1.6.0"
  }
}
